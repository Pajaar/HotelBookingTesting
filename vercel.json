{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.4",
      "config": {
        "phpIniPath": "php.ini"
      }
    },
    {
      "src": "Hotel-Booking-System/css/**",
      "use": "@vercel/static"
    },
    {
      "src": "Hotel-Booking-System/js/**",
      "use": "@vercel/static"
    },
    {
      "src": "Hotel-Booking-System/img/**",
      "use": "@vercel/static"
    },
    {
      "src": "Hotel-Booking-System/fonts/**",
      "use": "@vercel/static"
    },
    {
      "src": "Hotel-Booking-System/scss/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}