{
    "functions": {
        "HotelBooking/*.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
  "version": 2,
  "builds": [
    {
      "src": "Hotel-Booking-System/index.php",
      "use": "@vercel/php"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/Hotel-Booking-System/index.php" },
    { "src": "/(.*)", "dest": "/Hotel-Booking-System/$1" }
  ]
}
